# ┌─────────────────────────────────────────────────────────────────────────┐
# │  TiCore — Environment Configuration Example                             │
# │                                                                         │
# │  Copy this file to .env and fill in your values.                        │
# │  .env is NEVER committed to version control.                            │
# │                                                                         │
# │  Variables here are loaded by TiCore/src/Core/DotEnv.php and exposed   │
# │  via getenv(), $_ENV, and $_SERVER.                                     │
# └─────────────────────────────────────────────────────────────────────────┘


# ── Application ───────────────────────────────────────────────────────────────

# APP_ENV controls error display, log level defaults, and stack trace visibility.
#   development  — display_errors ON, full exception traces, LOG_LEVEL defaults to 3
#   production   — display_errors OFF, silent errors, LOG_LEVEL defaults to 1
APP_ENV=development


# ── Logging ───────────────────────────────────────────────────────────────────

# LOG_LEVEL controls what gets written to TiCore/logs/app-YYYY-MM-DD.log
# and which PHP error types are reported (error_reporting bitmask).
# If not set, defaults to 3 in development and 1 in production.
#
#   0 = CRITICAL   — fatal errors, parse failures, compile errors only
#   1 = ERROR      — runtime errors (+ critical)
#   2 = WARNING    — warnings, notices (+ error + critical)
#   3 = INFO       — informational log entries (+ above)
#   4 = DEPRECATED — deprecated / user-deprecated notices (+ above)
#   5 = DEBUG      — E_ALL, E_STRICT, verbose debug traces (+ above)
LOG_LEVEL=3


# ── Database ──────────────────────────────────────────────────────────────────

# Database credentials are only used when DB_ENABLED is set to true in
# TiCore/config.php. The connection uses PDO with utf8mb4 charset and
# prepared statements (SQL injection safe by default).
#
# DB_HOST  — hostname or IP of your MySQL / MariaDB server
# DB_NAME  — the database / schema name to connect to
# DB_USER  — database username (use a least-privilege account in production)
# DB_PASS  — database password
DB_HOST=localhost
DB_NAME=ticore_db
DB_USER=ticore_user
DB_PASS=change_me_to_a_strong_password


# ── Notes ─────────────────────────────────────────────────────────────────────
#
# The following settings are NOT environment variables — they are PHP constants
# defined directly in TiCore/config.php. Edit that file to change them:
#
#   SITE_TITLE       — displayed in <title> and JSON-LD  (default: TiCore Secure Framework)
#   BASE_URL         — used for canonical URLs and OG tags (default: https://ticore.tuxxin.com)
#   DB_ENABLED       — true | false  — enables/disables the PDO database layer
#   SITEMAP_ENABLED  — true | false  — exposes /sitemap.xml to crawlers
#
# Per-page SEO meta tags are set by passing variables to view() in your controller.
# See TiCore/templates/default/layouts/header.php for the full reference.
