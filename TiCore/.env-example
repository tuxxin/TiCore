# Copy to .env and fill in. NEVER commit .env.
APP_ENV=production
LOG_LEVEL=1

# ── Site identity ──
SITE_TITLE="My TiCore Site"
BASE_URL=https://example.com
SITE_LOGO=
FACEBOOK_URL=
GA4_ID=
ADSENSE_CLIENT=

# ── Database (set DB_ENABLED=true to use MySQL/PDO) ──
DB_ENABLED=false
DB_HOST=localhost
DB_NAME=
DB_USER=
DB_PASS=

# ── Structured-data classifier (optional; see the schema-generator addon) ──
# SITE_ORG_NAME=
# SITE_ORG_TYPE=Organization
# SITE_SAMEAS=
# SITE_CATEGORY=
# SITE_CONTACT_EMAIL=

# ── Addon keys (only needed if you install the addon) ──
# payments — USE TEST KEYS IN DEV (sk_test_/pk_test_)
STRIPE_SECRET_KEY=
STRIPE_PUB_KEY=
STRIPE_WEBHOOK_SECRET=
PAYPAL_CLIENT_ID=
PAYPAL_SECRET=
PAYPAL_ENV=sandbox
# contact-mailer (MailerSend)
MAILERSEND_API_KEY=
MAILERSEND_FROM_EMAIL=
CONTACT_EMAIL=
# indexnow
INDEXNOW_KEY=
# google-analytics-gsc (service account)
GOOGLE_APPLICATION_CREDENTIALS=
GA4_PROPERTY_ID=
GSC_SITE=
# rest-api-kit (server-side console key)
RESTAPIKIT_CONSOLE_KEY=
