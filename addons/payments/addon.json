{
  "slug": "payments",
  "name": "TiCore Payments",
  "version": "1.0.0",
  "description": "Stripe + PayPal payments/subscriptions via dependency-free REST clients. Checkout, webhooks, and a GA4 purchase event. Keys read from .env.",
  "author": "tuxxin",
  "license": "MIT",
  "ticore": ">=2.0.0",
  "php": ">=8.1",
  "requires_db": false,
  "autoload": { "Tuxxin\\TiCore\\Addons\\Payments\\": "src/" },
  "bootstrap": "Tuxxin\\TiCore\\Addons\\Payments\\PaymentsAddon",
  "routes": { "web": "routes/web.php" },
  "views": { "namespace": "payments", "path": "views" },
  "config": { "file": "config/payments.php" },
  "env": {
    "optional": [
      "STRIPE_SECRET_KEY", "STRIPE_PUB_KEY", "STRIPE_WEBHOOK_SECRET",
      "PAYPAL_CLIENT_ID", "PAYPAL_SECRET", "PAYPAL_ENV",
      "PAYMENTS_CURRENCY", "PAYMENTS_GA4_ID"
    ]
  },
  "files": [
    "addon.json",
    "config/payments.php",
    "src/PaymentsAddon.php",
    "src/Stripe.php",
    "src/PayPal.php",
    "src/Controllers/CheckoutController.php",
    "routes/web.php",
    "views/checkout.php",
    "views/success.php"
  ]
}
